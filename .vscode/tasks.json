{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "watch",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Init Python venv",
            "type": "shell",
            "command": "python -m venv .venv && .venv\\Scripts\\pip install -U pip && if (Test-Path requirements.txt) { .venv\\Scripts\\pip install -r requirements.txt }",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Install Node deps",
            "type": "shell",
            "command": "npm install",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build extension",
            "type": "shell",
            "command": "npm run compile",
            "dependsOn": ["Install Node deps", "Init Python venv"],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Run FastAPI server",
            "type": "shell",
            "command": ".venv\\Scripts\\python.exe fastapi_server.py",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "(.*)",
                            "file": 1,
                            "location": 2,
                            "message": 3
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "INFO:     Started server",
                        "endsPattern": "Uvicorn running on"
                    }
                }
            ],
            "group": "build"
        }
    ]
}