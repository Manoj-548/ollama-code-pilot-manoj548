{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "watch",
            "problemMatcher": "$tsc-watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Init Python venv",
            "type": "shell",
            "command": "python -m venv .venv && .venv\\Scripts\\pip install -U pip && if (Test-Path requirements.txt) { .venv\\Scripts\\pip install -r requirements.txt }",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Install Node deps",
            "type": "shell",
            "command": "npm install",
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Build extension",
            "type": "shell",
            "command": "npm run compile",
            "dependsOn": ["Install Node deps", "Init Python venv"],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "Run FastAPI server",
            "type": "shell",
            "command": ".venv\\Scripts\\uvicorn.exe fastapi_server:app --reload --host 0.0.0.0 --port 8000",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": [
                {
                    "pattern": [
                        {
                            "regexp": "(.*)",
                            "line": 0
                        }
                    ],
                    "background": {
                        "activeOnStart": true,
                        "beginsPattern": "^.*(INFO|WARNING):.*",
                        "endsPattern": "^.*(Uvicorn running on|Application startup complete).*"
                    }
                }
            ],
            "group": "build"
        },
        {
            "label": "Lint code",
            "type": "shell",
            "command": "npm run lint",
            "problemMatcher": ["$eslint"],
            "group": "build"
        },
        {
            "label": "Setup all",
            "type": "shell",
            "dependsOn": [
                "Init Python venv",
                "Install Node deps",
                "Build extension",
                "Lint code"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "Setup and Run All",
            "type": "shell",
            "dependsOn": [
                "Setup all",
                "Run FastAPI server"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "group": "build"
        }
    ]
}